# -----------------------------------------------------------------------------
# App (lib/config.ts → config.app)
# -----------------------------------------------------------------------------
# Public site URL (emails, links). Defaults to http://localhost:3000 if unset.
app__base_url=http://localhost:3000
# Optional override for config.app.nodeEnv; otherwise NODE_ENV is used.
app__node_env=development
# Structured logging — JSON to stdout, scraped into Loki.
# Minimum level: debug | info | warn | error. Defaults to info in production, debug otherwise.
app__log_level=info
# Service label attached to every log line (becomes a Loki label).
app__service_name=ajd-site

# -----------------------------------------------------------------------------
# NocoDB — required for users, CMS, presigned links (see getters in lib/config.ts)
# -----------------------------------------------------------------------------
nocodb__base_url=
nocodb__api_token=
nocodb__users__table_id=
nocodb__users__view_id=
# Optional — content pages disabled if either is missing
nocodb__cms__table_id=
nocodb__cms__view_id=
nocodb__presigned_links__table_id=
nocodb__presigned_links__view_id=
nocodb__candidates__table_id=
nocodb__candidates__view_id=
# Campaigns + per-recipient send log (required for the campaign sender)
nocodb__campaigns__table_id=
nocodb__campaigns__view_id=
nocodb__campaign_sends__table_id=
nocodb__campaign_sends__view_id=

# -----------------------------------------------------------------------------
# Features (optional)
# -----------------------------------------------------------------------------
features__whatsapp_link=
features__geocodio_api_key=

# -----------------------------------------------------------------------------
# Twilio (email + SMS) — optional; omit for local dev (links log to console)
# Email uses the Twilio Communications API (comms.twilio.com/v1/Emails).
# -----------------------------------------------------------------------------
twilio__account_sid=
twilio__auth_token=
# Verified sender address in Twilio Email
twilio__from_email=
# Optional display name for the From header (defaults to American Jews for Democracy)
twilio__from_name=
# SMS only
twilio__messaging_phone_number=

# -----------------------------------------------------------------------------
# Campaign sending (required to run email/SMS campaigns)
# -----------------------------------------------------------------------------
# Shared secret sent by the NocoDB webhook to /api/campaigns/send (X-Campaign-Secret header)
campaigns__webhook_secret=
# Signing key for stateless unsubscribe links (generate a long random string)
unsubscribe__secret=
# Optional physical mailing address for email footers (only needed for commercial mail)
org__postal_address=
