# -----------------------------------------------------------------------------
# App (lib/config.ts → config.app)
# -----------------------------------------------------------------------------
# Public site URL (emails, links). Defaults to http://localhost:3000 if unset.
app__base_url=http://localhost:3000
# Optional override for config.app.nodeEnv; otherwise NODE_ENV is used.
app__node_env=development

# -----------------------------------------------------------------------------
# NocoDB — required for users, CMS, presigned links (see getters in lib/config.ts)
# -----------------------------------------------------------------------------
nocodb__base_url=
nocodb__api_token=
nocodb__users__table_id=
nocodb__users__view_id=
# Optional — content pages disabled if either is missing
nocodb__cms__table_id=
nocodb__cms__view_id=
nocodb__presigned_links__table_id=
nocodb__presigned_links__view_id=
nocodb__candidates__table_id=
nocodb__candidates__view_id=

# -----------------------------------------------------------------------------
# Features (optional)
# -----------------------------------------------------------------------------
features__whatsapp_link=
features__geocodio_api_key=

# -----------------------------------------------------------------------------
# Twilio SendGrid (email) — optional; omit for local dev (links log to console)
# -----------------------------------------------------------------------------
twilio__sendgrid_api_key=
# Verified sender or domain in SendGrid
twilio__from_email=

# -----------------------------------------------------------------------------
# Twilio SMS — optional
# -----------------------------------------------------------------------------
twilio__account_sid=
twilio__auth_token=
twilio__messaging_phone_number=
